# .streamlit/secrets.toml.example
# Copy this file to .streamlit/secrets.toml and fill in your actual values.
# IMPORTANT: Never commit your actual secrets.toml to version control.

CEREBRAS_API_KEY = "YOUR_CEREBRAS_API_KEY_HERE"

# --- LLM Settings ---
LLM_PROVIDER = "cerebras"
LLM_MODEL = "gemma-4-31b"
LLM_TEMPERATURE = "0.7"
LLM_MAX_TOKENS = "1024"

# --- Retrieval & Vector Store ---
EMBEDDING_MODEL = "all-MiniLM-L6-v2"
CHROMA_PERSIST_DIR = "./data/chroma"
CHROMA_COLLECTION_NAME = "email_responses"
RETRIEVAL_TOP_K = "5"

# --- Evaluation Settings ---
EVAL_LLM_MODEL = "gemma-4-31b"
EVAL_LLM_TEMPERATURE = "0.1"

# --- Paths ---
DATASET_PATH = "./dataset/emails.csv"
OUTPUTS_DIR = "./outputs"
REPORTS_DIR = "./outputs/reports"

# --- Logging ---
LOG_LEVEL = "INFO"
